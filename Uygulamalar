const int butonPini = 7;
const int ledPini = 8;

int ledDurumu = LOW;         // LED'in anlık durumunu hafızada tutarız
int sonButonDurumu = HIGH;   // Butonun bir önceki döngüdeki durumu (PULLUP olduğu için ilk hali HIGH)

void setup() {
  pinMode(ledPini, OUTPUT);
  pinMode(butonPini, INPUT_PULLUP);
}

void loop() {
  int anlikButonDurumu = digitalRead(butonPini);

  // Eğer butonun durumu değişmişse ve yeni durum LOW (basılı) ise:
  if (anlikButonDurumu == LOW && sonButonDurumu == HIGH) {
    
    // LED kapalıysa aç, açıksa kapat
    if (ledDurumu == LOW) {
      ledDurumu = HIGH;
    } else {
      ledDurumu = LOW;
    }
    
    // Yeni durumu LED'e gönder
    digitalWrite(ledPini, ledDurumu);
    
    // Ark (debounce) engelleme: Butonun içindeki mekanik yaylanmayı es geçmek için
    delay(50); 
  }

  // Bir sonraki döngü için şu anki durumu "son durum" olarak kaydet
  sonButonDurumu = anlikButonDurumu;
}




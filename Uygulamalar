const int trigPin = 9;
const int echoPin = 10;

// 5 adet LED'in bağlı olduğu pinler
const int ledPinleri[] = {2, 3, 4, 5, 6}; 

long sure;
int mesafe;

void setup() {
  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);
  
  // Bir for döngüsü ile 5 LED pinini de ÇIKIŞ (OUTPUT) olarak ayarlıyoruz
  for(int i = 0; i < 5; i++) {
    pinMode(ledPinleri[i], OUTPUT);
  }
  
  Serial.begin(9600);
}

void loop() {
  // Mesafe okuma işlemleri
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);
  
  sure = pulseIn(echoPin, HIGH);
  mesafe = sure * 0.034 / 2;
  
  Serial.print("Mesafe: ");
  Serial.println(mesafe);
  
  // Mesafeye göre LED'leri yakıp söndürme mantığı
  // Cisim yaklaştıkça yanan LED sayısı artar.
  
  if (mesafe < 50) digitalWrite(ledPinleri[0], HIGH); 
  else digitalWrite(ledPinleri[0], LOW);
  
  if (mesafe < 40) digitalWrite(ledPinleri[1], HIGH); 
  else digitalWrite(ledPinleri[1], LOW);
  
  if (mesafe < 30) digitalWrite(ledPinleri[2], HIGH); 
  else digitalWrite(ledPinleri[2], LOW);
  
  if (mesafe < 20) digitalWrite(ledPinleri[3], HIGH); 
  else digitalWrite(ledPinleri[3], LOW);
  
  if (mesafe < 10) digitalWrite(ledPinleri[4], HIGH); // En yakın (Tehlike)
  else digitalWrite(ledPinleri[4], LOW);
  
  delay(50);
}


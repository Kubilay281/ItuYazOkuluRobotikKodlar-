const int butonPini = 7; 
const int ledPini = 8;   

void setup() {
  pinMode(ledPini, OUTPUT);
  // INPUT_PULLUP ile Arduino'nun içindeki direnci aktif ediyoruz
  pinMode(butonPini, INPUT_PULLUP); 
}

void loop() {
  // Butonun durumunu oku
  int butonDurumu = digitalRead(butonPini);

  // Butona basıldığında (durum LOW olduğunda) LED'i yak
  if (butonDurumu == LOW) {
    digitalWrite(ledPini, HIGH);
  } 
  // Basılmadığında (durum HIGH olduğunda) LED'i söndür
  else {
    digitalWrite(ledPini, LOW);
  }
}



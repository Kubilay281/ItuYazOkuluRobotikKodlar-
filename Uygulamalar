int ledPin = 9; // LED'in bağlı olduğu pin

void setup() {
  pinMode(ledPin, OUTPUT); // Pini çıkış olarak ayarlıyoruz
}

void loop() {
  digitalWrite(ledPin, HIGH); // LED'e güç ver (Yak)
  delay(1000);                // 1000 milisaniye (1 saniye) bekle
  digitalWrite(ledPin, LOW);  // LED'in gücünü kes (Söndür)
  delay(1000);                // 1 saniye bekle
}




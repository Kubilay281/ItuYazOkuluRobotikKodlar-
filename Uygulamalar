int ledPin = 9; 

void setup() {
  pinMode(ledPin, OUTPUT);
}

void loop() {
  // Parlaklığı 0'dan 255'e kadar yavaşça artır
  for (int parlaklik = 0; parlaklik <= 255; parlaklik++) {
    analogWrite(ledPin, parlaklik); // PWM pini için analogWrite kullanılır
    delay(10); // Değişimi gözle görebilmek için kısa bir bekleme
  }
  
  // Parlaklığı 255'ten 0'a kadar yavaşça azalt
  for (int parlaklik = 255; parlaklik >= 0; parlaklik--) {
    analogWrite(ledPin, parlaklik);
    delay(10);
  }
}



const int trigPin = 9;
const int echoPin = 10;

long sure;
int mesafe;

void setup() {
  pinMode(trigPin, OUTPUT); // Ses dalgası gönderen pin
  pinMode(echoPin, INPUT);  // Yankıyı dinleyen pin
  Serial.begin(9600);       // Değerleri ekranda görmek için
}

void loop() {
  // 1. Sensörün temiz bir sinyal göndermesi için Trig pinini sıfırla
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);
  
  // 2. 10 mikrosaniyelik bir ses dalgası gönder
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);
  
  // 3. Yankının dönme süresini ölç (mikrosaniye cinsinden)
  sure = pulseIn(echoPin, HIGH);
  
  // 4. Süreyi santimetre cinsinden mesafeye çevir
  mesafe = sure * 0.034 / 2;
  
  // 5. Sonucu Seri Port Ekranına yazdır
  Serial.print("Mesafe: ");
  Serial.print(mesafe);
  Serial.println(" cm");
  
  delay(100); // Ölçümlerin birbirine karışmaması için kısa bir bekleme
}



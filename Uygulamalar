int potPin = A0;
int ledPin = 9;
int potDeger = 0;
int parlaklik = 0;

void setup() {
  pinMode(ledPin, OUTPUT);
  Serial.begin(9600);
}

void loop() {
  // 1. Sensörden veriyi oku (0 - 1023)
  potDeger = analogRead(potPin); 
  
  // 2. Okunan değeri parlaklık aralığına dönüştür
  // map(değişken, mevcut_min, mevcut_maks, hedef_min, hedef_maks)
  parlaklik = map(potDeger, 0, 1023, 0, 255); 
  
  // 3. Dönüştürülen değeri LED'e gönder
  analogWrite(ledPin, parlaklik); 
  
  // 4. Değerleri ekrandan takip et
  Serial.print("Pot Degeri: ");
  Serial.print(potDeger);
  Serial.print(" | LED Parlakligi: ");
  Serial.println(parlaklik);
  
  delay(50);
}



